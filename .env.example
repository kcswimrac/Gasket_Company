# Neon Postgres
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# AutoQuote Bridge API
AUTOQUOTE_BASE_URL=http://forge-mac-mini.<your-tailnet>.ts.net
AUTOQUOTE_BRIDGE_TOKEN=<token-from-operator-via-secure-channel>

# Auth.js secret — generate with: openssl rand -hex 32
AUTH_SECRET=<generate-with-openssl-rand-hex-32>

# Legacy shared admin password (bootstrap: used only when no admin_users exist)
ADMIN_PASSWORD=<shared-admin-password>
